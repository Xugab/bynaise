# Environment Variables — by-naise
# Copy file ini ke .env.local dan isi nilainya

# ============================================
# DATABASE (Heroku Postgres)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/bynaise_dev"

# ============================================
# NEXTAUTH (Authentication)
# ============================================
# Generate dengan: openssl rand -base64 32
# Atau: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="GANTI_INI_DENGAN_RANDOM_STRING_PANJANG"

# URL aplikasi — domain kamu
NEXTAUTH_URL="https://bynaise.biz.id"

# ============================================
# CLOUDINARY (Upload Gambar Produk)
# ============================================
# Daftar gratis di: https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ============================================
# ADMIN (Email admin pertama)
# ============================================
ADMIN_EMAIL="admin@bynaise.com"
